generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  telegramId    BigInt   @unique
  username      String?
  firstName     String?
  lastName      String?
  photoUrl      String?
  freeCredits   Int      @default(100)  // 金币 (gold coins, free currency)
  paidCredits   Int      @default(0)   // 钻石 (diamonds, paid currency)
  lastCheckIn   DateTime?              // last daily check-in timestamp
  checkInStreak Int      @default(0)   // consecutive check-in days
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  characters    Character[]   @relation("CharacterCreator")
  conversations Conversation[]
  reviews       Review[]
  payments      Payment[]

  @@index([telegramId])
}

model Character {
  id            String   @id @default(uuid())
  creatorId     String
  name          String
  age           Int
  gender        String
  occupation    String
  personality   String   @db.Text
  background    String   @db.Text
  speakingStyle String   @db.Text
  avatarEmoji   String   @default("🤖")
  portraitUrl    String?            // AI-generated character portrait (main cover)
  faceUrl        String?            // Close-up face headshot, used as chat avatar
  portraitImages Json     @default("[]")  // Array of image URLs for the swipeable gallery
  openingScene   String?  @db.Text  // Seductive opening scene shown at start of conversation
  isPublic      Boolean  @default(true)
  usageCount    Int      @default(0)
  avgRating     Float    @default(0)
  reviewCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator       User          @relation("CharacterCreator", fields: [creatorId], references: [id])
  conversations Conversation[]
  reviews       Review[]

  @@index([isPublic, usageCount])
  @@index([avgRating])
}

model Conversation {
  id            String   @id @default(uuid())
  userId        String
  characterId   String
  // stored as JSON array of {role, content} objects
  contextJson   Json     @default("[]")
  totalTurns    Int      @default(0)
  // user memory: facts we learned about this user
  userMemory    Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  character     Character @relation(fields: [characterId], references: [id])
  messages      Message[]

  @@unique([userId, characterId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
}

model Review {
  id          String   @id @default(uuid())
  userId      String
  characterId String
  rating      Int      // 1-5
  comment     String?  @db.Text
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])

  @@unique([userId, characterId])
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  telegramPayload Json
  turnsGranted    Int
  stars           Int
  createdAt       DateTime @default(now())

  user            User @relation(fields: [userId], references: [id])
}

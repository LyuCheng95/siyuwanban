generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  telegramId    BigInt   @unique
  username      String?
  firstName     String?
  lastName      String?
  photoUrl      String?
  nickname      String?
  isAnonymous   Boolean  @default(false)
  freeCredits   Int      @default(0)   // 金币 (gold coins, check-in rewards)
  paidCredits   Int      @default(0)   // 钻石 (diamonds, paid currency for chat)
  lastCheckIn   DateTime?              // last daily check-in timestamp
  checkInStreak Int      @default(0)   // consecutive check-in days
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  characters    Character[]   @relation("CharacterCreator")
  conversations Conversation[]
  reviews       Review[]
  payments      Payment[]
  redeemedCodes RedeemCode[]

  @@index([telegramId])
}

model Character {
  id            String   @id @default(uuid())
  creatorId     String
  name          String
  age           Int
  gender        String
  occupation    String
  personality   String   @db.Text
  background    String   @db.Text
  speakingStyle String   @db.Text
  avatarEmoji   String   @default("🤖")
  portraitUrl    String?            // AI-generated character portrait (main cover)
  faceUrl        String?            // Close-up face headshot, used as chat avatar
  portraitImages Json     @default("[]")  // Array of image URLs for the swipeable gallery
  openingScene   String?  @db.Text  // Seductive opening scene shown at start of conversation
  isPublic      Boolean  @default(true)
  usageCount    Int      @default(0)
  avgRating     Float    @default(0)
  reviewCount   Int      @default(0)
  storyPhases   Json?             // [p0, p1, p2, p3, p4] — AI-generated or manually written
  imageModel      String?           // leosam | jugger | noob | pony (defaults to leosam)
  height          Int?              // cm
  weight          Int?              // kg
  faceFeatures    String?  @db.Text // distinctive face/body prompt (eye shape, jaw, skin tone…)
  faceAnchor      String?  @db.Text // mood/style anchor keywords for consistent face across images
  defaultOutfit   String?  @db.Text // default clothing description used in scene generation
  portraitPrompts Json?             // pre-written ComfyUI portrait prompts (replaces ALBUM_CONFIGS)
  qaStatus      String?           // pending | running | passed | failed
  qaScore       Int?              // 0-100
  qaReport      Json?             // { categories, score, summary, issues, suggestions }
  qaRunAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator       User          @relation("CharacterCreator", fields: [creatorId], references: [id])
  conversations Conversation[]
  reviews       Review[]
  sceneImages   SceneImage[]

  @@index([isPublic, usageCount])
  @@index([avgRating])
}

model SceneImage {
  id          String   @id @default(uuid())
  characterId String
  prompt      String   @db.Text
  imageUrl    String
  useCount    Int      @default(1)
  createdAt   DateTime @default(now())

  character   Character @relation(fields: [characterId], references: [id])

  @@index([characterId, createdAt])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Conversation {
  id            String   @id @default(uuid())
  userId        String
  characterId   String
  // stored as JSON array of {role, content} objects
  contextJson   Json     @default("[]")
  totalTurns    Int      @default(0)
  // user memory: facts we learned about this user
  userMemory    Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  character     Character @relation(fields: [characterId], references: [id])
  messages      Message[]

  @@unique([userId, characterId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
}

model Review {
  id          String   @id @default(uuid())
  userId      String
  characterId String
  rating      Int      // 1-5
  comment     String?  @db.Text
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])

  @@unique([userId, characterId])
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  provider        String   // 'stripe' | 'crypto' | 'admin'
  externalId      String?  @unique  // Stripe PaymentIntent ID / tx hash
  status          String   @default("pending")  // pending | completed | failed
  amountUsd       Float    @default(0)  // USD amount charged
  currency        String   @default("usd")
  diamondsGranted Int
  metadata        Json     @default("{}")  // raw provider payload
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
}

model RedeemCode {
  id              String    @id @default(uuid())
  code            String    @unique
  diamondsGranted Int       @default(100)
  isUsed          Boolean   @default(false)
  usedById        String?
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  usedBy          User?     @relation(fields: [usedById], references: [id])
}
